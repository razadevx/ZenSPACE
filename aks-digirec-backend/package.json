{
  "name": "aks-digirec-backend",
  "version": "1.0.0",
  "description": "AKS DigiRec - Multi-tenant SaaS ERP for Ceramics Manufacturing",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "seed": "node src/utils/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "erp",
    "ceramics",
    "manufacturing",
    "accounting",
    "inventory",
    "saas",
    "multi-tenant"
  ],
  "author": "AKS DigiRec",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1499.0",
    "nodemailer": "^6.9.7",
    "dayjs": "^1.11.10",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/utils/seed.js"
    ]
  }
}
