              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"companyName\": \"My Ceramics Factory\",\n  \"phone\": \"+923001234567\"\n}"
